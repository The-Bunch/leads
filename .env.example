# HelloBill Partner API credentials
# sb_* = sandbox, live_* = production (strict realm isolation — cross-realm IDs 404)
HELLOBILL_CLIENT_ID=sb_xxxxxxxxxxxx
HELLOBILL_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# Optional — defaults to https://partnerapi.hellobill.app/api/v1
# (do NOT use api.hellobill.app — that host does not resolve)
# HELLOBILL_API_BASE_URL=https://partnerapi.hellobill.app/api/v1
